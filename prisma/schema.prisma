generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Currency {
  PEN
  USD
}

enum RateType {
  EFECTIVA
  NOMINAL
}

enum GraceType {
  NONE
  PARTIAL
  TOTAL
}

model User {
  id            Int               @id @default(autoincrement())
  username      String            @unique
  passwordHash  String
  role          String            @default("VENDEDOR")
  email         String?           @unique
  telefono      String?
  createdAt     DateTime          @default(now())
  ultimoAcceso  DateTime?
  configuration Configuration?
  credits       VehicularCredit[]
}

model Client {
  id                   Int               @id @default(autoincrement())
  dni                  String            @unique
  nombres              String
  apellidos            String
  correo               String
  telefono             String
  consentimientoDatos  Boolean           @default(false)
  fechaConsentimiento  DateTime?
  credits              VehicularCredit[]
}

model Vehicle {
  id           Int               @id @default(autoincrement())
  marca        String
  modelo       String
  precioVenta  Decimal
  moneda       Currency
  tipoMotor    String?
  anio         Int?
  vidaUtilAnos Int?
  cilindrada   String?
  transmision  String?
  credits      VehicularCredit[]
  service      VehicleService?
}

model VehicleService {
  id                       Int       @id @default(autoincrement())
  vehicleId                Int       @unique
  vehicle                  Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  tieneMantenimiento       Boolean   @default(false)
  descripcionMantenimiento String?
  costoMantenimientoAnual  Decimal?
  tieneSOAT                Boolean   @default(false)
  vigenciaSOAT             DateTime?
  tieneSeguroVehicular     Boolean   @default(false)
  coberturaSiniestro       String?
}

model Configuration {
  id                    Int      @id @default(autoincrement())
  userId                Int      @unique
  defaultMoneda         Currency @default(PEN)
  defaultTipoTasa       RateType @default(EFECTIVA)
  defaultCapitalizacion Int      @default(30)
  defaultBaseAnual      Int      @default(360)
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VehicularCredit {
  id                          Int             @id @default(autoincrement())
  userId                      Int
  clientId                    Int
  vehicleId                   Int
  moneda                      Currency
  precioVehiculo              Decimal
  cuotaInicialPorcentaje      Decimal
  cuotaBalonPorcentaje        Decimal
  tipoTasa                    RateType
  tasaInteres                 Decimal
  capitalizacionDias          Int             @default(30)
  plazoMeses                  Int
  fechaDesembolso             DateTime
  periodoGraciaTipo           GraceType       @default(NONE)
  periodosGracia              Int             @default(0)
  seguroDesgravamenPorcentaje Decimal
  seguroVehicularPorcentaje   Decimal
  portesMontoFijo             Decimal
  baseAnual                   Int             @default(360)
  tasaDescuentoAnual          Decimal         @default(12)
  createdAt                   DateTime        @default(now())
  updatedAt                   DateTime        @updatedAt
  user                        User            @relation(fields: [userId], references: [id])
  client                      Client          @relation(fields: [clientId], references: [id])
  vehicle                     Vehicle         @relation(fields: [vehicleId], references: [id])
  metrics                     FinancialMetric?
  cashFlows                   CashFlow[]
}

model FinancialMetric {
  id       Int             @id @default(autoincrement())
  creditId Int             @unique
  van      Decimal
  tir      Decimal
  tcea     Decimal
  credit   VehicularCredit @relation(fields: [creditId], references: [id], onDelete: Cascade)
}

model CashFlow {
  id                Int             @id @default(autoincrement())
  creditId          Int
  numeroMes         Int
  fechaPago         DateTime
  saldoInicial      Decimal
  interes           Decimal
  amortizacion      Decimal
  seguroDesgravamen Decimal
  seguroVehicular   Decimal
  cuota             Decimal
  saldoFinal        Decimal
  credit            VehicularCredit @relation(fields: [creditId], references: [id], onDelete: Cascade)
}
